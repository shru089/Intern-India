# ── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/
MONGODB_DB=intern_india

# SQLite is used as a fallback for the scraper layer during local development.
# For production, replace with a real PostgreSQL URL:
# DATABASE_URL=postgresql://user:pass@host:5432/intern_india
DATABASE_URL=sqlite:///./intern_india.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 32
JWT_SECRET=change-me-before-deploying
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173

# ── Telegram Notifications (Optional) ────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Scraper ───────────────────────────────────────────────────────────────────
INTERNSHALA_PAGES=3
SCRAPE_INTERVAL_MINUTES=60

# ── App env ───────────────────────────────────────────────────────────────────
ENV=development
